{
  "name": "@mcp-plus-plus/validators-ts",
  "version": "1.0.0",
  "description": "TypeScript validators for MCP++ protocol compliance",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
