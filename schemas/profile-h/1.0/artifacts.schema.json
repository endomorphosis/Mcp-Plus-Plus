{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcp-plus-plus.dev/schemas/profile-h/1.0/artifacts.schema.json",
  "title": "MCP++ Profile H 1.0 canonical artifacts",
  "description": "Closed DAG-JSON shapes. Semantic, CID codec, expiry, redaction, and negotiated-bound checks are additionally enforced by the Profile H codecs.",
  "oneOf": [
    {"$ref": "#/$defs/PaidCapability"}, {"$ref": "#/$defs/PaymentQuote"},
    {"$ref": "#/$defs/PaymentAuthorization"}, {"$ref": "#/$defs/PaymentVerification"},
    {"$ref": "#/$defs/SettlementReceipt"}, {"$ref": "#/$defs/PaidEntitlement"},
    {"$ref": "#/$defs/UsageRecord"}, {"$ref": "#/$defs/RefundRecord"},
    {"$ref": "#/$defs/AccessReceipt"}
  ],
  "$defs": {
    "cid": {"type": "string", "pattern": "^b[a-z2-7]+$", "maxLength": 128},
    "did": {"type": "string", "pattern": "^did:[a-z0-9]+:[A-Za-z0-9._:%-]+(?:[/?#][^\\u0000]*)?$", "maxLength": 512},
    "time": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
    "amount": {"type": "string", "pattern": "^(?:0|[1-9][0-9]{0,77})$"},
    "network": {"type": "string", "pattern": "^[a-z0-9-]{3,8}:[A-Za-z0-9_-]{1,32}$"},
    "sig": {"type": "string", "pattern": "^[A-Za-z0-9_-]{86}$"},
    "common": {
      "type": "object", "required": ["schema", "createdAt", "parents", "correlationId"],
      "properties": {"schema": {"type": "string"}, "createdAt": {"$ref": "#/$defs/time"}, "parents": {"type": "array", "maxItems": 256, "uniqueItems": true, "items": {"$ref": "#/$defs/cid"}}, "correlationId": {"type": "string", "minLength": 1, "maxLength": 128}}
    },
    "requirement": {
      "type": "object", "additionalProperties": false,
      "required": ["scheme", "network", "asset", "amount", "payTo", "maxTimeoutSeconds", "extra"],
      "properties": {"scheme": {"type": "string", "minLength": 1, "maxLength": 64}, "network": {"$ref": "#/$defs/network"}, "asset": {"type": "string", "minLength": 1, "maxLength": 256}, "amount": {"$ref": "#/$defs/amount"}, "payTo": {"type": "string", "minLength": 1, "maxLength": 256}, "maxTimeoutSeconds": {"type": "integer", "minimum": 1, "maximum": 3600}, "extra": {"type": "object"}}
    },
    "PaidCapability": {
      "allOf": [{"$ref": "#/$defs/common"}, {"type": "object", "additionalProperties": false,
        "required": ["schema","createdAt","parents","correlationId","serverDid","descriptorCid","interfaceCid","operationKind","operationName","httpMethod","httpRoute","catalogVersion","ability","policyCid","termsCid","scheme","network","asset","amount","payee","validFrom","expiresAt","settlementTiming","sellerDid","signatureAlg","signature"],
        "properties": {"schema":{"const":"mcp++/profile-h/paid-capability@1.0"},"createdAt":{"$ref":"#/$defs/time"},"parents":{"type":"array","items":{"$ref":"#/$defs/cid"}},"correlationId":{"type":"string"},"serverDid":{"$ref":"#/$defs/did"},"descriptorCid":{"$ref":"#/$defs/cid"},"interfaceCid":{"$ref":"#/$defs/cid"},"operationKind":{"enum":["tool","resource","prompt","http"]},"operationName":{"type":"string","minLength":1,"maxLength":256},"httpMethod":{"type":["string","null"],"enum":["GET","POST","PUT","PATCH","DELETE",null]},"httpRoute":{"type":["string","null"],"maxLength":512},"catalogVersion":{"type":"string","minLength":1,"maxLength":64},"ability":{"type":"string","minLength":1,"maxLength":256},"policyCid":{"$ref":"#/$defs/cid"},"termsCid":{"$ref":"#/$defs/cid"},"scheme":{"type":"string","minLength":1,"maxLength":64},"network":{"$ref":"#/$defs/network"},"asset":{"type":"string","minLength":1,"maxLength":256},"amount":{"$ref":"#/$defs/amount"},"payee":{"type":"string","minLength":1,"maxLength":256},"validFrom":{"$ref":"#/$defs/time"},"expiresAt":{"$ref":"#/$defs/time"},"settlementTiming":{"enum":["immediate","metered","batched"]},"sellerDid":{"$ref":"#/$defs/did"},"signatureAlg":{"const":"Ed25519"},"signature":{"$ref":"#/$defs/sig"}}}]},
    "PaymentQuote": {
      "allOf": [{"$ref":"#/$defs/common"},{"type":"object","additionalProperties":false,"required":["schema","createdAt","parents","correlationId","capabilityCid","catalogCid","descriptorCid","requestCid","requirements","nonce","expiresAt","idempotencyKey","sellerDid","signatureAlg","signature"],"properties":{"schema":{"const":"mcp++/profile-h/payment-quote@1.0"},"createdAt":{"$ref":"#/$defs/time"},"parents":{"type":"array","items":{"$ref":"#/$defs/cid"}},"correlationId":{"type":"string"},"capabilityCid":{"$ref":"#/$defs/cid"},"catalogCid":{"$ref":"#/$defs/cid"},"descriptorCid":{"$ref":"#/$defs/cid"},"requestCid":{"$ref":"#/$defs/cid"},"requirements":{"type":"array","minItems":1,"maxItems":32,"items":{"$ref":"#/$defs/requirement"}},"nonce":{"type":"string","minLength":1,"maxLength":128},"expiresAt":{"$ref":"#/$defs/time"},"idempotencyKey":{"type":"string","minLength":1,"maxLength":128},"sellerDid":{"$ref":"#/$defs/did"},"signatureAlg":{"const":"Ed25519"},"signature":{"$ref":"#/$defs/sig"}}}]},
    "PaymentAuthorization": {"allOf":[{"$ref":"#/$defs/common"},{"type":"object","additionalProperties":false,"required":["schema","createdAt","parents","correlationId","quoteCid","requestCid","requirementIndex","paymentPayloadCid","payerCommitment","signedPayloadCommitment","signatureCommitment"],"properties":{"schema":{"const":"mcp++/profile-h/payment-authorization@1.0"},"createdAt":{"$ref":"#/$defs/time"},"parents":{"type":"array","items":{"$ref":"#/$defs/cid"}},"correlationId":{"type":"string"},"quoteCid":{"$ref":"#/$defs/cid"},"requestCid":{"$ref":"#/$defs/cid"},"requirementIndex":{"type":"integer","minimum":0,"maximum":31},"paymentPayloadCid":{"$ref":"#/$defs/cid"},"payerCommitment":{"$ref":"#/$defs/cid"},"signedPayloadCommitment":{"$ref":"#/$defs/cid"},"signatureCommitment":{"$ref":"#/$defs/cid"}}}]},
    "PaymentVerification": {"allOf":[{"$ref":"#/$defs/common"},{"type":"object","additionalProperties":false,"required":["schema","createdAt","parents","correlationId","authorizationCid","verifierDid","decision","reasonCode","verifiedAt","expiresAt","evidenceCid"],"properties":{"schema":{"const":"mcp++/profile-h/payment-verification@1.0"},"createdAt":{"$ref":"#/$defs/time"},"parents":{"type":"array","items":{"$ref":"#/$defs/cid"}},"correlationId":{"type":"string"},"authorizationCid":{"$ref":"#/$defs/cid"},"verifierDid":{"$ref":"#/$defs/did"},"decision":{"enum":["verified","rejected"]},"reasonCode":{"type":"string","minLength":1,"maxLength":128},"verifiedAt":{"$ref":"#/$defs/time"},"expiresAt":{"$ref":"#/$defs/time"},"evidenceCid":{"$ref":"#/$defs/cid"}}}]},
    "SettlementReceipt": {"allOf":[{"$ref":"#/$defs/common"},{"type":"object","additionalProperties":false,"required":["schema","createdAt","parents","correlationId","verificationCid","outcome","amount","network","networkReferenceCommitment","disclosurePolicy","paymentResponseCid","settledAt"],"properties":{"schema":{"const":"mcp++/profile-h/settlement-receipt@1.0"},"createdAt":{"$ref":"#/$defs/time"},"parents":{"type":"array","items":{"$ref":"#/$defs/cid"}},"correlationId":{"type":"string"},"verificationCid":{"$ref":"#/$defs/cid"},"outcome":{"enum":["settled","failed","pending","reconciliation-required","refunded"]},"amount":{"$ref":"#/$defs/amount"},"network":{"$ref":"#/$defs/network"},"networkReferenceCommitment":{"$ref":"#/$defs/cid"},"disclosurePolicy":{"enum":["commitment-only","authorized","public"]},"paymentResponseCid":{"$ref":"#/$defs/cid"},"settledAt":{"$ref":"#/$defs/time"}}}]},
    "PaidEntitlement": {"allOf":[{"$ref":"#/$defs/common"},{"type":"object","additionalProperties":false,"required":["schema","createdAt","parents","correlationId","settlementCid","subjectCommitment","capabilityCid","quotaUnits","consumedUnits","unit","expiresAt"],"properties":{"schema":{"const":"mcp++/profile-h/paid-entitlement@1.0"},"createdAt":{"$ref":"#/$defs/time"},"parents":{"type":"array","items":{"$ref":"#/$defs/cid"}},"correlationId":{"type":"string"},"settlementCid":{"$ref":"#/$defs/cid"},"subjectCommitment":{"$ref":"#/$defs/cid"},"capabilityCid":{"$ref":"#/$defs/cid"},"quotaUnits":{"$ref":"#/$defs/time"},"consumedUnits":{"$ref":"#/$defs/time"},"unit":{"type":"string","minLength":1,"maxLength":128},"expiresAt":{"$ref":"#/$defs/time"}}}]},
    "UsageRecord": {"allOf":[{"$ref":"#/$defs/common"},{"type":"object","additionalProperties":false,"required":["schema","createdAt","parents","correlationId","entitlementCid","unit","inputCid","outputCid","units","recordedAt"],"properties":{"schema":{"const":"mcp++/profile-h/usage-record@1.0"},"createdAt":{"$ref":"#/$defs/time"},"parents":{"type":"array","items":{"$ref":"#/$defs/cid"}},"correlationId":{"type":"string"},"entitlementCid":{"$ref":"#/$defs/cid"},"unit":{"type":"string","minLength":1,"maxLength":128},"inputCid":{"$ref":"#/$defs/cid"},"outputCid":{"$ref":"#/$defs/cid"},"units":{"type":"integer","minimum":1,"maximum":9007199254740991},"recordedAt":{"$ref":"#/$defs/time"}}}]},
    "RefundRecord": {"allOf":[{"$ref":"#/$defs/common"},{"type":"object","additionalProperties":false,"required":["schema","createdAt","parents","correlationId","settlementCid","requestCid","decision","outcome","evidenceCid","requestedAt","decidedAt"],"properties":{"schema":{"const":"mcp++/profile-h/refund-record@1.0"},"createdAt":{"$ref":"#/$defs/time"},"parents":{"type":"array","items":{"$ref":"#/$defs/cid"}},"correlationId":{"type":"string"},"settlementCid":{"$ref":"#/$defs/cid"},"requestCid":{"$ref":"#/$defs/cid"},"decision":{"enum":["requested","approved","denied"]},"outcome":{"enum":["pending","refunded","failed","not-applicable"]},"evidenceCid":{"$ref":"#/$defs/cid"},"requestedAt":{"$ref":"#/$defs/time"},"decidedAt":{"$ref":"#/$defs/time"}}}]},
    "AccessReceipt": {"allOf":[{"$ref":"#/$defs/common"},{"type":"object","additionalProperties":false,"required":["schema","createdAt","parents","correlationId","operationName","requestCid","ucanDecisionCid","policyDecisionCid","leaseDecisionCid","commercialEvidenceCid","decision","resultCid","reasonCode","decidedAt"],"properties":{"schema":{"const":"mcp++/profile-h/access-receipt@1.0"},"createdAt":{"$ref":"#/$defs/time"},"parents":{"type":"array","items":{"$ref":"#/$defs/cid"}},"correlationId":{"type":"string"},"operationName":{"type":"string","minLength":1,"maxLength":256},"requestCid":{"$ref":"#/$defs/cid"},"ucanDecisionCid":{"anyOf":[{"$ref":"#/$defs/cid"},{"type":"null"}]},"policyDecisionCid":{"anyOf":[{"$ref":"#/$defs/cid"},{"type":"null"}]},"leaseDecisionCid":{"anyOf":[{"$ref":"#/$defs/cid"},{"type":"null"}]},"commercialEvidenceCid":{"anyOf":[{"$ref":"#/$defs/cid"},{"type":"null"}]},"decision":{"enum":["allow","deny"]},"resultCid":{"anyOf":[{"$ref":"#/$defs/cid"},{"type":"null"}]},"reasonCode":{"type":"string","minLength":1,"maxLength":128},"decidedAt":{"$ref":"#/$defs/time"}}}]}
  }
}
