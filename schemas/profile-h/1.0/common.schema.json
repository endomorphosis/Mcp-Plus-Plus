{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcp-plus-plus.dev/schemas/profile-h/1.0/common.schema.json",
  "title": "MCP++ Profile H 1.0 common definitions",
  "$defs": {
    "cid": {"type": "string", "pattern": "^b[a-z2-7]+$", "maxLength": 128},
    "did": {"type": "string", "pattern": "^did:[a-z0-9]+:[A-Za-z0-9._:%-]+(?:[/?#][^\\u0000]*)?$", "maxLength": 512},
    "timestamp": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
    "amount": {"type": "string", "pattern": "^(?:0|[1-9][0-9]{0,77})$"},
    "network": {"type": "string", "pattern": "^[a-z0-9-]{3,8}:[A-Za-z0-9_-]{1,32}$"},
    "signature": {"type": "string", "pattern": "^[A-Za-z0-9_-]{86}$"},
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scheme", "network", "asset", "amount", "payTo", "maxTimeoutSeconds", "extra"],
      "properties": {
        "scheme": {"type": "string", "minLength": 1, "maxLength": 64},
        "network": {"$ref": "#/$defs/network"},
        "asset": {"type": "string", "minLength": 1, "maxLength": 256},
        "amount": {"$ref": "#/$defs/amount"},
        "payTo": {"type": "string", "minLength": 1, "maxLength": 256},
        "maxTimeoutSeconds": {"type": "integer", "minimum": 1, "maximum": 3600},
        "extra": {"type": "object"}
      }
    }
  }
}
