{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcp-plus-plus.dev/schemas/profile-h/1.0/x402-v2.schema.json",
  "title": "Profile H decoded x402 v2 transport objects",
  "description": "Transport-only objects. PAYMENT-REQUIRED and PAYMENT-SIGNATURE are standard padded base64 of canonical UTF-8 JSON; PAYMENT-RESPONSE uses the same codec.",
  "oneOf": [{"$ref":"#/$defs/PaymentRequired"},{"$ref":"#/$defs/PaymentPayload"},{"$ref":"#/$defs/SettlementResponse"}],
  "$defs": {
    "network":{"type":"string","pattern":"^[a-z0-9-]{3,8}:[A-Za-z0-9_-]{1,32}$"},
    "amount":{"type":"string","pattern":"^(?:0|[1-9][0-9]{0,77})$"},
    "requirement":{"type":"object","additionalProperties":false,"required":["scheme","network","asset","amount","payTo","maxTimeoutSeconds","extra"],"properties":{"scheme":{"type":"string","minLength":1},"network":{"$ref":"#/$defs/network"},"asset":{"type":"string","minLength":1},"amount":{"$ref":"#/$defs/amount"},"payTo":{"type":"string","minLength":1},"maxTimeoutSeconds":{"type":"integer","minimum":1,"maximum":3600},"extra":{"type":"object"}}},
    "PaymentRequired":{"type":"object","additionalProperties":false,"required":["x402Version","accepts"],"properties":{"x402Version":{"const":2},"error":{"type":"string"},"resource":{"type":"object"},"accepts":{"type":"array","minItems":1,"maxItems":32,"items":{"$ref":"#/$defs/requirement"}},"extensions":{"type":"object"}}},
    "PaymentPayload":{"type":"object","additionalProperties":false,"required":["x402Version","accepted","payload"],"properties":{"x402Version":{"const":2},"resource":{"type":"object"},"accepted":{"$ref":"#/$defs/requirement"},"payload":{"type":"object"},"extensions":{"type":"object"}}},
    "SettlementResponse":{"type":"object","additionalProperties":false,"required":["success","network"],"properties":{"success":{"type":"boolean"},"errorReason":{"type":"string"},"transaction":{"type":["string","null"]},"network":{"$ref":"#/$defs/network"},"payer":{"type":"string"},"extensions":{"type":"object"}}}
  }
}
